{
  "nodeModulesDir": "auto",
  "tasks": {
    "check:lint-eslint": "deno run -A npm:eslint src",
    "check:lint-deno": "deno lint",
    "check:types": "deno check",
    "dev:watch": "deno run -A npm:vite build --watch",
    "dev:serve": "deno run -A scripts/serve.ts",
    "build": "deno run -A npm:vite build"
  },
  "compilerOptions": {
    "lib": [
      "deno.ns",
      "dom",
      "dom.iterable",
      "esnext"
    ]
  },
    "lint": {
    "include": ["src/", "eslint.config.mjs", "scripts/", "vite.config.ts"],
  },
  "imports": {
    "@eslint/js": "npm:@eslint/js@^10.0.1",
    "eslint": "npm:eslint@^10.5.0",
    "eslint-plugin-perfectionist": "npm:eslint-plugin-perfectionist@^5.9.1",
    "eslint-plugin-unicorn": "npm:eslint-plugin-unicorn@^67.0.0",
    "globals": "npm:globals@^17.6.0",
    "typescript": "npm:typescript@^6.0.3",
    "typescript-eslint": "npm:typescript-eslint@^8.61.1",
    "vite": "npm:vite@^8.0.16",
    "vite-plugin-css-injected-by-js": "npm:vite-plugin-css-injected-by-js@^5.0.1"
  }
}
